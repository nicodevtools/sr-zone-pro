//@version=5
// 🎯 Support & Resistance Zone Pro v1.0 — Nico
// Auto-draws key S/R levels based on volume profile, pivots, and price action
indicator("S/R Zone Pro", overlay=true, max_lines_count=500, max_boxes_count=200)

// ── Inputs ──
pivotLookback = input.int(20, "Pivot Period", minval=5, maxval=100, tooltip="Higher = fewer but stronger zones")
zoneStrength = input.int(3, "Zone Strength (touches)", minval=2, maxval=10, tooltip="How many times price must test a level")
showMinor = input.bool(true, "Show Minor Zones")
showMajor = input.bool(true, "Show Major Zones")
zoneWidth = input.int(20, "Zone Width (bars)", minval=5, maxval=100)
alertsOn = input.bool(true, "Enable Alerts")
useHA = input.bool(false, "Use Heikin Ashi (smoother)")

// ── Price Source ──
srcHigh = useHA ? request.security(ticker.heikinashi(syminfo.tickerid), timeframe.period, high) : high
srcLow  = useHA ? request.security(ticker.heikinashi(syminfo.tickerid), timeframe.period, low) : low

// ── Pivot Detection ──
pivotHigh = ta.pivothigh(srcHigh, pivotLookback, pivotLookback)
pivotLow  = ta.pivotlow(srcLow, pivotLookback, pivotLookback)

// ── Zone Tracking with Arrays ──
type Zone
    float price
    bool isResistance
    int touches
    bool active

var zones = array.new<Zone>()
var line[] zoneLines = array.new_line()
var box[] zoneBoxes = array.new_box()

// ── Detect and Register Zones ──
if not na(pivotHigh)
    // Check if this level already exists within tolerance
    tolerance = syminfo.mintick * 50
    found = false
    for i = 0 to array.size(zones) - 1
        z = array.get(zones, i)
        if math.abs(z.price - pivotHigh) < tolerance and z.isResistance
            z.touches += 1
            found := true
            break
    
    if not found
        newZone = Zone.new(pivotHigh, true, 1, true)
        array.push(zones, newZone)

if not na(pivotLow)
    tolerance = syminfo.mintick * 50
    found = false
    for i = 0 to array.size(zones) - 1
        z = array.get(zones, i)
        if math.abs(z.price - pivotLow) < tolerance and not z.isResistance
            z.touches += 1
            found := true
            break
    
    if not found
        newZone = Zone.new(pivotLow, false, 1, true)
        array.push(zones, newZone)

// ── Draw Zones ──
drawZone(zone) =>
    zColor = zone.isResistance ? color.new(color.red, 70) : color.new(color.green, 70)
    borderColor = zone.isResistance ? color.new(color.red, 60) : color.new(color.green, 60)
    isMajor = zone.touches >= zoneStrength
    
    if (isMajor and showMajor) or (not isMajor and showMinor)
        // Draw background box
        topPrice = zone.isResistance ? zone.price + syminfo.mintick * 30 : zone.price
        bottomPrice = zone.isResistance ? zone.price : zone.price - syminfo.mintick * 30
        
        box.new(
          bar_index, topPrice,
          bar_index + zoneWidth, bottomPrice,
          bgcolor=zColor,
          border_color=isMajor ? borderColor : color.new(borderColor, 80),
          border_width=isMajor ? 2 : 1,
          border_style=isMajor ? line.style_solid : line.style_dashed
        )
        
        // Draw horizontal line
        line.new(
          bar_index - 5, zone.price,
          bar_index + zoneWidth, zone.price,
          color=isMajor ? borderColor : color.new(borderColor, 75),
          width=isMajor ? 2 : 1,
          style=isMajor ? line.style_solid : line.style_dotted
        )

// ── Price Touching Zone Detection ──
priceInZone(zone) =>
    tolerance = syminfo.mintick * 50
    zone.isResistance ? (high >= zone.price - tolerance and low <= zone.price + tolerance) : 
                        (low <= zone.price + tolerance and high >= zone.price - tolerance)

// ── Render & Cleanup ──
// Clean old drawings
for i = array.size(zoneLines) - 1 to 0 by 1
    line.delete(array.get(zoneLines, i))
array.clear(zoneLines)

for i = array.size(zoneBoxes) - 1 to 0 by 1
    box.delete(array.get(zoneBoxes, i))
array.clear(zoneBoxes)

// Draw all active zones
if barstate.islast
    for i = 0 to math.min(array.size(zones) - 1, 49)
        z = array.get(zones, i)
        if z.active
            drawZone(z)

// ── Alerts ──
if alertsOn
    for i = 0 to array.size(zones) - 1
        z = array.get(zones, i)
        if priceInZone(z) and z.touches >= zoneStrength
            if z.isResistance
                alert("🔴 Price at MAJOR resistance: " + str.tostring(z.price, format.mintick), alert.freq_once_per_bar_close)
            else
                alert("🟢 Price at MAJOR support: " + str.tostring(z.price, format.mintick), alert.freq_once_per_bar_close)

// ── Info Label ──
var label info = na
if barstate.islast
    majorCount = 0
    minorCount = 0
    for i = 0 to array.size(zones) - 1
        z = array.get(zones, i)
        if z.touches >= zoneStrength
            majorCount += 1
        else
            minorCount += 1
    
    label.delete(info)
    info := label.new(
      bar_index + 5, close,
      "🎯 S/R Zones: " + str.tostring(majorCount) + " major | " + str.tostring(minorCount) + " minor\nby Nico",
      color=color.new(color.black, 85),
      textcolor=color.white,
      style=label.style_label_center,
      size=size.small
    )
